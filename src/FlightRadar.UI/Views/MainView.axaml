<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FlightRadar.UI.Views"
             x:Class="FlightRadar.UI.Views.MainView">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="32"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="#1a1a2e">
      <StackPanel Orientation="Horizontal" Margin="10,0">
        <Border Width="8" Height="8" CornerRadius="4" Background="{Binding StatusBrush}" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding ConnectionStatus}" Foreground="#aaa" FontSize="11" Margin="6,0,10,0" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding AircraftCountDisplay}" Foreground="#aaa" FontSize="11" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding LastUpdateDisplay}" Foreground="#666" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
    <views:RadarCanvas Grid.Row="1"
                       Aircraft="{Binding Aircraft}"
                       CenterLat="{Binding CenterLat}"
                       CenterLon="{Binding CenterLon}"/>
  </Grid>
</UserControl>
