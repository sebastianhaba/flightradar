<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FlightRadar.UI.Views"
             x:Class="FlightRadar.UI.Views.MainView">
  <TabControl TabStripPlacement="Bottom">
    <TabItem Header="Aktualnie">
      <views:LiveView/>
    </TabItem>
    <TabItem Header="Historia">
      <views:HistoryView DataContext="{Binding History}"/>
    </TabItem>
  </TabControl>
</UserControl>
