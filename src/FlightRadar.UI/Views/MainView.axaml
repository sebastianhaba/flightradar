<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FlightRadar.UI.Views"
             x:Class="FlightRadar.UI.Views.MainView">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="32"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="#1a1a2e">
      <StackPanel Orientation="Horizontal" Margin="10,0">
        <Border Width="8" Height="8" CornerRadius="4" Background="{Binding StatusBrush}" VerticalAlignment="Center"/>
        <TextBlock Classes="status" Text="{Binding ConnectionStatus}" Margin="6,0,10,0"/>
        <TextBlock Classes="status" Text="{Binding AircraftCountDisplay}"/>
        <TextBlock Classes="status-muted" Text="{Binding LastUpdateDisplay}"/>
      </StackPanel>
    </Border>
    <SplitView Grid.Row="1"
               DisplayMode="CompactInline"
               IsPaneOpen="{Binding SidePanel.IsPanelOpen}"
               OpenPaneLength="260"
               CompactPaneLength="48"
               PanePlacement="Right">
      <SplitView.Pane>
        <views:SidePanelView DataContext="{Binding SidePanel}"/>
      </SplitView.Pane>
      <SplitView.Content>
        <views:RadarCanvas Aircraft="{Binding Aircraft}"
                           CenterLat="{Binding CenterLat}"
                           CenterLon="{Binding CenterLon}"/>
      </SplitView.Content>
    </SplitView>
  </Grid>
</UserControl>
