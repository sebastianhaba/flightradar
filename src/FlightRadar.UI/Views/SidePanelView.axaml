<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FlightRadar.UI.ViewModels"
             xmlns:conv="clr-namespace:FlightRadar.UI.Converters"
             x:Class="FlightRadar.UI.Views.SidePanelView"
             x:DataType="vm:SidePanelViewModel">
  <Grid ColumnDefinitions="48,*">
    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,8,0,0">
      <Button Margin="0,0,0,4" Classes="icon-toggle"
              Command="{Binding TogglePanelCommand}">
        <TextBlock Text="☰" Foreground="#ccc" FontSize="18"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
    </StackPanel>

    <Grid Grid.Column="1" Margin="4,0,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="320"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Classes="panel-header" Text="Lista statków"/>

      <Grid Grid.Row="0" ColumnDefinitions="50,*,45,35" Margin="0,20,0,0">
        <TextBlock Grid.Column="0" Classes="table-header" Text="Czas"/>
        <TextBlock Grid.Column="1" Classes="table-header" Text="Znak"/>
        <TextBlock Grid.Column="2" Classes="table-header" Text="Alt"/>
        <TextBlock Grid.Column="3" Classes="table-header" Text="Kurs"/>
      </Grid>

      <ListBox Grid.Row="1" Name="AircraftList" Classes="transparent"
               ItemsSource="{Binding Aircraft}"
               SelectedItem="{Binding SelectedAircraft, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="50,*,45,35"
                  Opacity="{Binding IsStale, Converter={x:Static conv:StaleOpacityConverter.Instance}}"
                  Margin="0,1,0,1">
              <TextBlock Grid.Column="0" Classes="table-data"
                         Text="{Binding FirstSeenLocal, StringFormat={}{0:HH:mm}}"/>
              <TextBlock Grid.Column="1" Foreground="#ddd" FontSize="10"
                         Text="{Binding Callsign}"/>
              <TextBlock Grid.Column="2" Classes="table-data" HorizontalAlignment="Center"
                         Text="{Binding Altitude}"/>
              <TextBlock Grid.Column="3" Classes="table-data" HorizontalAlignment="Center"
                         Text="{Binding Heading, StringFormat={}{0:F0}}"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#1a1a2e" Padding="4">
        <ContentControl Content="{Binding Detail}">
          <ContentControl.DataTemplates>
            <DataTemplate DataType="vm:DetailViewModel">
              <Grid>
                <TextBlock Classes="detail-placeholder" IsVisible="{Binding !HasSelection}"
                           Text="Kliknij statek w tabeli aby zobaczyć szczegóły"/>

                <ScrollViewer IsVisible="{Binding HasSelection}" VerticalScrollBarVisibility="Auto">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                        ColumnDefinitions="80,*" Margin="0,4,0,0">
                    <TextBlock Grid.Row="0"  Grid.Column="0" Classes="detail-label" Text="Znak"/>
                    <TextBlock Grid.Row="0"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailCallsign}"/>
                    <TextBlock Grid.Row="1"  Grid.Column="0" Classes="detail-label" Text="ICAO"/>
                    <TextBlock Grid.Row="1"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailIcaoHex}"/>
                    <TextBlock Grid.Row="2"  Grid.Column="0" Classes="detail-label" Text="Rejestracja"/>
                    <TextBlock Grid.Row="2"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailRegistration}"/>
                    <TextBlock Grid.Row="3"  Grid.Column="0" Classes="detail-label" Text="Operator"/>
                    <TextBlock Grid.Row="3"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailOwnOp}"/>
                    <TextBlock Grid.Row="4"  Grid.Column="0" Classes="detail-label" Text="Typ"/>
                    <TextBlock Grid.Row="4"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailType}"/>
                    <TextBlock Grid.Row="5"  Grid.Column="0" Classes="detail-label" Text="Kod"/>
                    <TextBlock Grid.Row="5"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailTypeCode}"/>
                    <TextBlock Grid.Row="6"  Grid.Column="0" Classes="detail-label" Text="Opis"/>
                    <TextBlock Grid.Row="6"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailDescription}"/>
                    <TextBlock Grid.Row="7"  Grid.Column="0" Classes="detail-label" Text="Szer."/>
                    <TextBlock Grid.Row="7"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailLatitude, StringFormat={}{0:F4}}"/>
                    <TextBlock Grid.Row="8"  Grid.Column="0" Classes="detail-label" Text="Dł."/>
                    <TextBlock Grid.Row="8"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailLongitude, StringFormat={}{0:F4}}"/>
                    <TextBlock Grid.Row="9"  Grid.Column="0" Classes="detail-label" Text="Odległość"/>
                    <TextBlock Grid.Row="9"  Grid.Column="1" Classes="detail-value" Text="{Binding DetailDistanceKm, StringFormat={}{0:F1} km}"/>
                    <TextBlock Grid.Row="10" Grid.Column="0" Classes="detail-label" Text="Kierunek"/>
                    <TextBlock Grid.Row="10" Grid.Column="1" Classes="detail-value" Text="{Binding DetailBearing, StringFormat={}{0:F0}°}"/>
                    <TextBlock Grid.Row="11" Grid.Column="0" Classes="detail-label" Text="Wys. geom."/>
                    <TextBlock Grid.Row="11" Grid.Column="1" Classes="detail-value" Text="{Binding DetailAltitude, StringFormat={}{0} ft}"/>
                    <TextBlock Grid.Row="12" Grid.Column="0" Classes="detail-label" Text="Wys. baro."/>
                    <TextBlock Grid.Row="12" Grid.Column="1" Classes="detail-value" Text="{Binding DetailAltBaro, StringFormat={}{0} ft}"/>
                    <TextBlock Grid.Row="13" Grid.Column="0" Classes="detail-label" Text="Prędkość"/>
                    <TextBlock Grid.Row="13" Grid.Column="1" Classes="detail-value" Text="{Binding DetailGroundSpeed, StringFormat={}{0:F0} węz}"/>
                    <TextBlock Grid.Row="14" Grid.Column="0" Classes="detail-label" Text="Kurs"/>
                    <TextBlock Grid.Row="14" Grid.Column="1" Classes="detail-value" Text="{Binding DetailHeading, StringFormat={}{0:F0}°}"/>
                    <TextBlock Grid.Row="15" Grid.Column="0" Classes="detail-label" Text="Squawk"/>
                    <TextBlock Grid.Row="15" Grid.Column="1" Classes="detail-value" Text="{Binding DetailSquawk}"/>
                    <TextBlock Grid.Row="16" Grid.Column="0" Classes="detail-label" Text="Pierwszy raz"/>
                    <TextBlock Grid.Row="16" Grid.Column="1" Classes="detail-value" Text="{Binding DetailFirstSeen}"/>
                    <TextBlock Grid.Row="17" Grid.Column="0" Classes="detail-label" Text="Ostatni raz"/>
                    <TextBlock Grid.Row="17" Grid.Column="1" Classes="detail-value" Text="{Binding DetailLastSeen}"/>
                  </Grid>
                </ScrollViewer>
              </Grid>
            </DataTemplate>
          </ContentControl.DataTemplates>
        </ContentControl>
      </Border>
    </Grid>
  </Grid>
</UserControl>
